---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('writing', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { data } = post;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={data.title} description={data.description} type="article">
  <article class="wrap prose">
    <a class="back" href="/writing">← Writing</a>
    <time class="meta" datetime={data.pubDate.toISOString()}>{fmt(data.pubDate)}</time>
    <h1>{data.title}</h1>
    {data.tags.length > 0 && (
      <p class="tags">
        {data.tags.map((t) => <span class="tag">#{t}</span>)}
      </p>
    )}
    <div class="double-rule rule-sp"></div>
    <Content />
    {data.updated && (
      <p class="updated meta">Updated {fmt(data.updated)}</p>
    )}
  </article>
</Base>

<style>
  .prose { padding-top: 2rem; max-width: 44rem; }
  .back {
    font-family: var(--mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    display: inline-block;
    margin-bottom: 1.5rem;
  }
  h1 { margin-top: 0.5rem; }
  .tags { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .tag {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--ink-faint);
  }
  .rule-sp { margin: 1.5rem 0 var(--space); }
  .updated { margin-top: var(--space); }
</style>
